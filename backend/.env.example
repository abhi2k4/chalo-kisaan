# ── App ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
APP_VERSION=1.0.0
DEV_BYPASS_AUTH=false           # Set true in local dev to skip JWT auth checks

# ── AWS Credentials ──────────────────────────────────────────────────────────
# Use an IAM user with the chalokisaan-lambda-role permissions (see AWS_SETUP_GUIDE.md)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# ── S3 Buckets ───────────────────────────────────────────────────────────────
# Create these buckets first: see AWS_SETUP_GUIDE.md → Step 1
S3_ASSETS_BUCKET=chalokisaan-assets
S3_AUDIO_TEMP_BUCKET=chalokisaan-audio-temp
S3_MODELS_BUCKET=chalokisaan-models
S3_DATA_BUCKET=chalokisaan-data

# ── Amazon Bedrock ───────────────────────────────────────────────────────────
# Bearer token (Bedrock API key) — bypasses IAM marketplace payment requirement
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# Enable Nova models in Bedrock console → Model access → us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_LIGHT_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_IMAGE_MODEL_ID=amazon.nova-canvas-v1:0
BEDROCK_VISION_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_REGION=us-east-1

# Guardrails (optional — leave blank until configured)
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=1

# ── Amazon SageMaker ─────────────────────────────────────────────────────────
# Endpoints are created via sagemaker/deploy_sdxl.py and sagemaker/train_xgboost.py
# Leave blank to skip SageMaker features (Bedrock fallback is used instead)
SAGEMAKER_SDXL_ENDPOINT=chalokisaan-sdxl-endpoint
SAGEMAKER_XGBOOST_ENDPOINT=chalokisaan-xgboost-endpoint
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/chalokisaan-sagemaker-role

# ── DynamoDB tables ───────────────────────────────────────────────────────────
DYNAMO_LOGS_TABLE=chalokisaan-logs
DYNAMO_PLANS_TABLE=chalokisaan-plans

# ── Amazon Polly (TTS) ────────────────────────────────────────────────────────
# Kajal Neural voice requires: us-east-1, us-west-2, or eu-west-1
POLLY_REGION=us-east-1
POLLY_S3_CACHE_PREFIX=tts-cache

# ── Amazon Transcribe (STT) ───────────────────────────────────────────────────
# Languages supported: hi-IN, mr-IN, en-IN, pa-IN, gu-IN
# Leave blank to use default vocabulary
TRANSCRIBE_CUSTOM_VOCAB=

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local dev: spin up via docker-compose.yml
DATABASE_URL=postgresql://kisaan_admin:changeme@localhost:5432/chalo_kisaan
DATABASE_ECHO=false

# ── Authentication ───────────────────────────────────────────────────────────
# JWT (internal fallback — Cognito tokens are primary auth)
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=720         # 30 days — farmers shouldn't re-login constantly

# ── Amazon Cognito (Phone + Password auth) ────────────────────────────────────
COGNITO_USER_POOL_ID=           # e.g. ap-south-1_SGaPgFlzd
COGNITO_APP_CLIENT_ID=          # App client ID from Cognito console
COGNITO_CLIENT_SECRET=          # App client secret (leave blank if client has no secret)
COGNITO_REGION=ap-south-1

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://localhost:3000,https://localhost:3443

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

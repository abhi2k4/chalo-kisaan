# Production environment — used by `npm run build`
# Direct HTTPS backend — api.chalokisaan.in proxies to the ALB (no mixed-content).
#   https://www.chalokisaan.in      → React SPA (Amplify)
#   https://api.chalokisaan.in/api  → FastAPI backend
REACT_APP_API_URL=https://api.chalokisaan.in/api
REACT_APP_DEV_BYPASS_AUTH=false

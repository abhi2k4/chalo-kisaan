# Production environment — used by `npm run build`
# API calls use a relative path so the browser never makes cross-origin HTTP requests.
# Amplify rewrites /api/* → ALB internally (HTTPS terminated at Amplify edge).
#   https://chalokisaan.in        → React SPA (Amplify CDN)
#   https://chalokisaan.in/api/*  → proxied by Amplify to the ALB over HTTP internally
REACT_APP_API_URL=/api
REACT_APP_DEV_BYPASS_AUTH=false

# Production environment — used by `npm run build`
# Relative /api path — Amplify rewrites /api/* → ALB server-side (no mixed-content in browser).
#   https://chalokisaan.in/www  → React SPA (Amplify CloudFront)
#   https://chalokisaan.in/api  → FastAPI backend (proxied by Amplify → ALB HTTP internally)
REACT_APP_API_URL=/api
REACT_APP_DEV_BYPASS_AUTH=false
